VITE_API_BASE_URL=http://localhost:8787
VITE_CF_BASE_URL=https://beta2.lawsuitcasefinder.com/
## Optional per-tab overrides for top navigation. If set, these override the
## default links constructed from VITE_CF_BASE_URL / VITE_AI_BASE_URL.
## Examples (uncomment and edit to override):
VITE_NAV_DASHBOARD=https://beta2.lawsuitcasefinder.com/Lawsuit/dashboard
VITE_NAV_AI=/dashboard
VITE_NAV_CASELAW=https://beta2.lawsuitcasefinder.com/Lawsuit/caselaw
VITE_NAV_BAREACTS=https://beta2.lawsuitcasefinder.com/Lawsuit/bareacts
VITE_NAV_LAWCOMMISSION=https://beta2.lawsuitcasefinder.com/Lawsuit/lawcommission
VITE_NAV_NOTIFICATIONS=https://beta2.lawsuitcasefinder.com/Lawsuit/notifications
VITE_NAV_HISTORY=https://beta2.lawsuitcasefinder.com/Lawsuit/history

## Optional override for logout action. If set, the logout UI will use this URL
## instead of calling the `onLogout` callback.
VITE_NAV_LOGOUT=https://beta2.lawsuitcasefinder.com/Lawsuit/logout

VITE_CF_LOGIN_URL=https://beta2.lawsuitcasefinder.com/
VITE_CF_BUY_CREDITS_URL=https://beta2.lawsuitcasefinder.com/